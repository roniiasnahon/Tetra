{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Folder": {
      "title": "Folder",
      "description": "Folder metadata for organizing papers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Paper": {
      "title": "Paper",
      "description": "Research paper metadata and status.",
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "added": { "type": "string" },
        "fullTextStatus": { "type": "string" },
        "viewed": { "type": "string" },
        "fileType": { "type": "string" },
        "summary": { "type": "string" },
        "fileId": { "type": "string" },
        "mimetype": { "type": "string" },
        "extractedText": { "type": "string" },
        "folderId": { "type": "string" }
      },
      "required": ["title"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Persistent chat history.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "messages": {
          "type": "array",
          "items": { "type": "object" }
        },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "messages", "updatedAt"]
    },
    "Session": {
      "title": "Session",
      "description": "Active workspace state.",
      "type": "object",
      "properties": {
        "tabs": {
          "type": "array",
          "items": { "type": "object" }
        },
        "activeTabId": { "type": "string" },
        "messages": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "Annotation": {
      "title": "Annotation",
      "description": "User highlights and notes on a document.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileId": { "type": "string" },
        "text": { "type": "string" },
        "comment": { "type": "string" },
        "page": { "type": "number" },
        "color": { "type": "string" },
        "timestamp": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["id", "fileId", "text", "page", "timestamp", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/annotations/{annotationId}": {
      "schema": "Annotation",
      "description": "User document annotations."
    },
    "/users/{userId}/folders/{folderId}": {
      "schema": "Folder",
      "description": "User's research folders."
    },
    "/users/{userId}/papers/{paperId}": {
      "schema": "Paper",
      "description": "User's research papers."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "Chat",
      "description": "User's saved chat conversations."
    },
    "/users/{userId}/workspace/session": {
      "schema": "Session",
      "description": "User's current active workspace session state."
    }
  }
}
