{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/server.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "electron:dev": "electron .",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@iconify/react": "^6.0.2",
    "@solar-icons/react": "^1.1.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@types/multer": "^1.4.11",
    "@vitejs/plugin-react": "^5.0.4",
    "audiomotion-analyzer": "^4.5.4",
    "axios": "^1.17.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "html2pdf.js": "^0.14.0",
    "katex": "^0.17.0",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "marked-katex-extension": "^5.1.10",
    "megajs": "^1.3.10",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "openai": "^6.41.0",
    "pdfjs-dist": "^6.0.227",
    "pdfkit": "^0.18.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-textarea-autosize": "^8.5.9",
    "remark-gfm": "^4.0.1",
    "resend": "^6.14.0",
    "vite": "^6.2.3",
    "voyageai": "^0.4.0",
    "wavesurfer.js": "^7.12.7",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/xml2js": "^0.4.14",
    "autoprefixer": "^10.4.21",
    "electron": "^42.4.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.4.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "electron-builder": {
    "appId": "com.cosmiwise.app",
    "productName": "Cosmiwise",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "cosmi.png",
      "cosmi.ico",
      "dist/**/*"
    ],
    "win": {
      "icon": "cosmi.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "cosmi.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "cosmi.png",
      "target": [
        "AppImage",
        "deb",
        "zip"
      ],
      "maintainer": "Jam <jam@cosmiwise.app>",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cosmiwise",
      "installerIcon": "cosmi.ico",
      "uninstallerIcon": "cosmi.ico",
      "installerHeader": "assets/installerHeader.bmp",
      "installerSidebar": "assets/installerSidebar.bmp",
      "uninstallerSidebar": "assets/uninstallerSidebar.bmp",
      "license": "assets/license.txt",
      "runAfterFinish": true
    }
  }
}
