rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 1500;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Entity Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt'])
        && data.keys().size() <= 6
        && data.uid == request.auth.uid
        && data.email is string
        && data.createdAt is number
        && data.get('displayName', '') is string;
    }

    function isValidFolder(data) {
      return data.keys().hasAll(['id', 'name', 'createdAt'])
        && data.keys().size() <= 4
        && data.id is string
        && data.name is string
        && data.createdAt is number;
    }

    function isValidPaper(data) {
      return data.keys().hasAll(['title'])
        && data.title is string
        && data.get('author', '') is string
        && data.get('description', '') is string
        && data.get('url', '') is string
        && data.get('added', '') is string
        && data.get('fullTextStatus', '') is string
        && data.get('viewed', '') is string
        && data.get('fileType', '') is string
        && data.get('summary', '') is string
        && data.get('fileId', '') is string
        && data.get('mimetype', '') is string
        && data.get('extractedText', '') is string
        && data.get('folderId', '') is string;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['title', 'messages', 'updatedAt'])
        && data.title is string
        && data.messages is list
        && data.updatedAt is number;
    }

    function isValidSession(data) {
      return data.keys().hasAny(['tabs', 'activeTabId', 'messages'])
        && data.get('tabs', []) is list
        && data.get('activeTabId', '') is string
        && data.get('messages', []) is list;
    }

    function isValidAnnotation(data) {
      return data.keys().hasAll(['id', 'fileId', 'text', 'page', 'timestamp', 'uid'])
        && data.id is string
        && data.fileId is string
        && data.text is string
        && data.get('comment', '') is string
        && data.page is number
        && data.get('color', '') is string
        && data.timestamp is number
        && data.uid is string;
    }

    // 4. Collection Matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().uid == existing().uid;

      match /folders/{folderId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(folderId) && isValidFolder(incoming());
        allow update: if isOwner(userId) && isValidId(folderId) && isValidFolder(incoming())
          && incoming().id == existing().id;
        allow delete: if isOwner(userId) && isValidId(folderId);
      }

      match /papers/{paperId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(paperId) && isValidPaper(incoming());
        allow update: if isOwner(userId) && isValidId(paperId) && isValidPaper(incoming());
        allow delete: if isOwner(userId) && isValidId(paperId);
      }

      match /chats/{chatId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chatId) && isValidChat(incoming());
        allow update: if isOwner(userId) && isValidId(chatId) && isValidChat(incoming());
        allow delete: if isOwner(userId) && isValidId(chatId);
      }

      match /workspace/session {
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSession(incoming());
        allow update: if isOwner(userId) && isValidSession(incoming());
      }
      
      match /annotations/{annotationId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(annotationId) && isValidAnnotation(incoming());
        allow update: if isOwner(userId) && isValidId(annotationId) && isValidAnnotation(incoming())
          && incoming().id == existing().id;
        allow delete: if isOwner(userId) && isValidId(annotationId);
      }
    }

    // 5. Collaborative Workspaces
    match /shared_workspaces/{workspaceId} {
      allow get: if isValidId(workspaceId);
      allow create, update: if isValidId(workspaceId) && isValidSession(incoming());
      allow delete: if isValidId(workspaceId);

      match /folders/{folderId} {
        allow list, get: if isValidId(workspaceId);
        allow create, update: if isValidId(workspaceId) && isValidId(folderId) && isValidFolder(incoming());
        allow delete: if isValidId(workspaceId) && isValidId(folderId);
      }

      match /papers/{paperId} {
        allow list, get: if isValidId(workspaceId);
        allow create, update: if isValidId(workspaceId) && isValidId(paperId) && isValidPaper(incoming());
        allow delete: if isValidId(workspaceId) && isValidId(paperId);
      }

      match /chats/{chatId} {
        allow list, get: if isValidId(workspaceId);
        allow create, update: if isValidId(workspaceId) && isValidId(chatId) && isValidChat(incoming());
        allow delete: if isValidId(workspaceId) && isValidId(chatId);
      }

      match /annotations/{annotationId} {
        allow list, get: if isValidId(workspaceId);
        allow create, update: if isValidId(workspaceId) && isValidId(annotationId) && isValidAnnotation(incoming());
        allow delete: if isValidId(workspaceId) && isValidId(annotationId);
      }
      match /presence/{memberId} {
        allow read, write: if true;
      }

      match /visitors/{visitorId} {
        allow read, write: if true;
      }
    }

    // 6. Shared Libraries
    match /shared_libraries/{libraryId} {
      allow get: if isValidId(libraryId);
      allow create, update: if isValidId(libraryId);
      allow delete: if isValidId(libraryId);

      match /folders/{folderId} {
        allow list, get: if isValidId(libraryId);
        allow create, update: if isValidId(libraryId) && isValidId(folderId) && isValidFolder(incoming());
        allow delete: if isValidId(libraryId) && isValidId(folderId);
      }

      match /papers/{paperId} {
        allow list, get: if isValidId(libraryId);
        allow create, update: if isValidId(libraryId) && isValidId(paperId) && isValidPaper(incoming());
        allow delete: if isValidId(libraryId) && isValidId(paperId);
      }
    }

    // 7. Test connection match
    match /test/connection {
      allow get: if true;
    }
  }
}
