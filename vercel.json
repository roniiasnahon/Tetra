{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/cosmi.png",
      "dest": "/cosmi.png"
    },
    {
      "src": "/((?!.*\\.(?:png|svg|jpg|jpeg|webp|gif|ico|js|css|woff2|woff|ttf|otf|json)$|api/).*)",
      "dest": "/index.html"
    }
  ]
}
